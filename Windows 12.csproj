<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>Windows_12</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="background.png" />
    <None Remove="calc.png" />
    <None Remove="logo.png" />
    <None Remove="Notepad.png" />
    <None Remove="taskbar.png" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="background.png" />
    <Resource Include="calc.png" />
    <Resource Include="logo.png" />
    <Resource Include="Notepad.png" />
    <Resource Include="taskbar.png" />
  </ItemGroup>

</Project>
