<Page x:Class="Windows_12.StartMenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Windows_12"
      mc:Ignorable="d" 
      d:DesignHeight="407" d:DesignWidth="340"
      Title="StartMenu">

    <Grid>
        <Border BorderThickness="1" CornerRadius="20">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF969696"/>
                    <GradientStop Color="#FF969696" Offset="1"/>
                    <GradientStop Color="White" Offset="0.5"/>
                </LinearGradientBrush>
            </Border.Background>
            <Button HorizontalAlignment="Left" Height="90" Margin="9,17,0,0" VerticalAlignment="Top" Width="90" Foreground="{x:Null}" Background="{x:Null}" Click="OpenNotepad">
                <StackPanel Orientation="Vertical"  Width="90" Height="90">
                    <Image Source="/Notepad.png" Width="70" Margin="0,-5,0,0"/>
                    <TextBlock Text="Notepad" Foreground="Black" TextAlignment="Center"/>
                </StackPanel>
            </Button>
        </Border>
    </Grid>
</Page>
