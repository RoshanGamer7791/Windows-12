<Page x:Class="Windows_12.StartMenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Windows_12"
      mc:Ignorable="d" 
      d:DesignHeight="407" d:DesignWidth="340"
      Title="StartMenu">

    <Grid>
        <Border BorderThickness="1" CornerRadius="20">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF969696"/>
                    <GradientStop Color="#FF969696" Offset="1"/>
                    <GradientStop Color="White" Offset="0.5"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <Button Width="70" Height="70" VerticalAlignment="Top" Margin="0,5,20,0" Background="{x:Null}">
                    <StackPanel Orientation="Vertical" Width="70" Height="70">
                        <Image Source="/Notepad.png" Width="50" Margin="0,-5,0,0"/>
                        <TextBlock Text="Notepad" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Width="70" Height="70" Margin="0,-290,0,0" Background="{x:Null}" Click="OpenCalculator">
                    <StackPanel Orientation="Vertical">
                        <Image Source="/calc.png" Width="50" Margin="0,-2,0,0"/>
                        <TextBlock Text="Calculator"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
