<Window x:Class="Windows_12.Calculator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Windows_12"
        mc:Ignorable="d"
        Title="Calculator" Height="400" Width="225" Icon="/calc.png">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF969696"/>
            <GradientStop Color="White" Offset="0.5"/>
            <GradientStop Color="#FF969696" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <TextBox x:Name="Val1" HorizontalAlignment="Center" Height="50" Margin="0,10,0,0" TextWrapping="Wrap" Text="23" VerticalAlignment="Top" Width="205" FontSize="36" Background="{x:Null}" FontWeight="Bold"/>
        <TextBox x:Name="Val2" HorizontalAlignment="Center" Margin="0,65,0,0" TextWrapping="Wrap" Text="23" VerticalAlignment="Top" Width="205" Height="50" Background="{x:Null}" FontSize="36" FontWeight="Bold"/>
        <TextBlock x:Name="Ans" HorizontalAlignment="Center" Margin="0,120,0,0" TextWrapping="Wrap" Text="46" VerticalAlignment="Top" Height="50" Width="205" FontSize="36" FontWeight="Bold"/>
        <Button HorizontalAlignment="Left" Margin="42,192,0,0" VerticalAlignment="Top" Width="50" Height="50" Background="{x:Null}" FontSize="24" Content="+" FontWeight="Bold" Click="Add"/>
        <Button Content="-" HorizontalAlignment="Left" Height="50" Margin="132,192,0,0" VerticalAlignment="Top" Width="50" Background="{x:Null}" FontWeight="Bold" FontSize="24" Click="Subtract"/>
        <Button Content="*" HorizontalAlignment="Left" Margin="42,261,0,0" VerticalAlignment="Top" Width="50" Height="50" Background="{x:Null}" FontSize="48" Click="Times" FontWeight="Bold"/>
        <Button Content="/" HorizontalAlignment="Left" Margin="132,261,0,0" VerticalAlignment="Top" Height="50" Width="50" Background="{x:Null}" FontSize="24" FontWeight="Bold" Click="Divide"/>

    </Grid>
</Window>
